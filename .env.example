# 复制为 .env 后再替换占位符；不要提交 .env 或任何真实密钥。

# ─── Kimi / Moonshot（推荐：无 OpenAI Key 时用这个）────────────
# 在 https://platform.moonshot.cn 创建 Key
MOONSHOT_API_KEY=
# 国内默认 https://api.moonshot.cn/v1 ；国际站可用 https://api.moonshot.ai/v1
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
# 也可用别名：KIMI_API_KEY / KIMI_BASE_URL
# 默认模型 kimi-k2.6（联网搜索建议用该模型）
MINI_CLAUDE_MODEL=kimi-k2.6

# ─── 平台 API 边界 ────────────────────────────────────────────
# 至少使用 32 字节随机值；Compose 会要求该变量非空。
PLATFORM_API_KEY=REPLACE_WITH_RANDOM_PLATFORM_API_KEY
# 容器内必须监听所有接口；直接 java -jar 的安全默认值仍是 127.0.0.1。
# SERVER_ADDRESS=0.0.0.0

# HTTP 服务端口（直接运行默认 8080；Compose Web 默认 8088）
# SERVER_PORT=8088
WEB_PORT=8088

# ─── PostgreSQL / Docker Compose ───────────────────────────────
POSTGRES_DB=miniclaude
POSTGRES_USER=miniclaude
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_DATABASE_PASSWORD

# 直接 java -jar 连接 PostgreSQL 时取消注释；Compose 会自动设置容器内地址。
# DATABASE_URL=jdbc:postgresql://127.0.0.1:5432/miniclaude
# DATABASE_USERNAME=miniclaude
# DATABASE_PASSWORD=REPLACE_WITH_STRONG_DATABASE_PASSWORD
# DATABASE_DRIVER=org.postgresql.Driver

# 默认 local 使用 PostgreSQL durable store；Temporal 仅为未完整交付的可选边界。
PLATFORM_ORCHESTRATOR=local
# 只允许专用工作区，多个路径以逗号分隔。
PLATFORM_ALLOWED_WORKSPACES=/workspace

# ─── OpenAI 兼容中继（可选）──────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://aihubmix.com/v1
# MINI_CLAUDE_MODEL=gpt-4o-mini

# ─── Anthropic 兼容配置（可选）────────────────────────────────
# ANTHROPIC_API_KEY=sk-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com
